{
  "name": "open-mmorpg",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p apps/web && tsc --noEmit -p packages/i18n && tsc --noEmit -p packages/ui && tsc --noEmit -p scripts",
    "test": "bun test",
    "web:dev": "bun run --filter @omm/web dev",
    "web:build": "bun run --filter @omm/web build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.3.14",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
